<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#0D0D0D">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MANIFEESTO SNIPER"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.1"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Airdrop Farming Bot"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginTop="2dp" />

    <!-- Wallet row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp"
        android:background="#1A1A1A"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wallet: "
            android:textColor="#888888"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_wallet_addr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Not configured"
            android:textColor="#FFAA00"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btn_wallet_setup"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="SETUP"
            android:textSize="11sp"
            android:textStyle="bold"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <!-- Status row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:background="#1A1A1A"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bot Status: "
            android:textColor="#AAAAAA"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STOPPED"
            android:textColor="#FF4444"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Control buttons -->
    <Button
        android:id="@+id/btn_start_bot"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="START BOT"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#00FF88"
        android:textColor="#000000"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btn_stop_bot"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="STOP BOT"
        android:textSize="15sp"
        android:backgroundTint="#FF4444"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <!-- Live log area -->
    <ScrollView
        android:id="@+id/scroll_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:background="#111111">

        <TextView
            android:id="@+id/tv_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initializing..."
            android:textColor="#00FF88"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:padding="10dp"
            android:lineSpacingExtra="2dp" />
    </ScrollView>

</LinearLayout>
