<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#0D0D0D">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MANIFEESTO SNIPER"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.1"
        android:layout_marginTop="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Airdrop Farming Bot"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp" />

    <!-- 状态指示器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="48dp"
        android:background="#1A1A1A"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bot Status: "
            android:textColor="#AAAAAA"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STOPPED"
            android:textColor="#FF4444"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 统计卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campaigns"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tv_campaigns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="8dp" android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claimed ($)"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tv_claimed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textColor="#00FF88"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- 控制按钮 -->
    <Button
        android:id="@+id/btn_start_bot"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="START BOT"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#00FF88"
        android:textColor="#000000"
        android:layout_marginTop="32dp" />

    <Button
        android:id="@+id/btn_stop_bot"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="STOP BOT"
        android:textSize="16sp"
        android:backgroundTint="#FF4444"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp" />

    <!-- 日志区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="24dp"
        android:background="#111111">

        <TextView
            android:id="@+id/tv_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting to start..."
            android:textColor="#00FF88"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:padding="12dp" />
    </ScrollView>

</LinearLayout>
